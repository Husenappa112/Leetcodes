// Finding minimum depth of tree
int minDepth(struct TreeNode* root) {

    if(root == NULL)
        return 0;

    if(root->left == NULL)
        return minDepth(root->right) + 1;

    if(root->right == NULL)
        return minDepth(root->left) + 1;

    int count_left = minDepth(root->left);
    int count_right = minDepth(root->right);

    if(count_left < count_right)
        return count_left + 1;
    else
        return count_right + 1;
}
