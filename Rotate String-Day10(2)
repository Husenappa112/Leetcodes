// Rotation of Strings
#include <string.h>
bool rotateString(char* s, char* goal) {

    if(strlen(s) != strlen(goal))
        return false;

    int n = strlen(s);

    char *temp = (char*)malloc(2*n + 1);

    strcpy(temp, s);
    strcat(temp, s);

    if(strstr(temp, goal) != NULL)
        return true;

    return false;
}
