//Same tree means return true else false
bool isSameTree(struct TreeNode* p, struct TreeNode* q) {

    if(p == NULL && q == NULL)
        return true;

    if(p == NULL || q == NULL)
        return false;

    if(p->val != q->val)
        return false;

    if(isSameTree(p->left, q->left) == false)
        return false;

    if(isSameTree(p->right, q->right) == false)
        return false;

    return true;
}
