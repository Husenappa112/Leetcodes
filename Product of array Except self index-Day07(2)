// Product of array except self index
int* productExceptSelf(int* nums, int numsSize, int* returnSize) {

    int* re = (int*)malloc(numsSize * sizeof(int));
    *returnSize = numsSize;

    for(int i = 0; i < numsSize; i++) {

        int product = 1;

        for(int j = 0; j < numsSize; j++) {

            if(i != j) {
                product = product * nums[j];
            }
        }

        re[i] = product;
    }

    return re;
}
